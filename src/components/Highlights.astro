---
const highlights = [
  {
    id: "001",
    bodyHtml:
      'Co-architected <a href="https://www.valinor.co/products/harbor" target="_blank" rel="noopener noreferrer" class="text-[var(--white)] underline decoration-[var(--amber)]/50 underline-offset-4 hover:decoration-[var(--amber)] transition-colors">HarborOS</a>, a containerized deployable medical platform delivered to <span class="text-[var(--white)]">U.S. Marine Corps</span> and special operations forces. Guided the product through <span class="text-[var(--white)]">FedSTART</span> certification.',
  },
  {
    id: "002",
    bodyHtml:
      'Built visualization and data tooling used by <span class="text-[var(--white)]">Amazon Robotics</span> engineers across multiple programs. Engineered a 50x reduction in load times on the primary platform for R&D debugging.',
  },
  {
    id: "003",
    body: "Designed AI-assisted development workflows built on multi-agent orchestration — parallel autonomous execution under human-gated review, with 95%+ token reduction in retrieval-heavy tasks.",
  },
  {
    id: "004",
    body: "Trusted across roles to operate beyond assigned scope — scoping requirements directly with clients, leading architecture decisions, and earning mentorship from senior leadership for strategic contribution.",
  },
];
---

<section id="highlights" class="py-24">
  <div class="eyebrow mb-4"><span class="mark">◈</span> 02 / HIGHLIGHTS</div>
  <h2
    class="text-4xl md:text-6xl text-[var(--white)] font-light tracking-tight mb-12"
  >
    Select <em class="text-[var(--amber)] not-italic font-normal"
      >missions.</em
    >
  </h2>
  <div class="grid md:grid-cols-2 gap-5">
    {
      highlights.map((h) => (
        <div class="card">
          <div class="card-num mb-4">HIGHLIGHT / {h.id}</div>
          {h.bodyHtml ? (
            <p class="text-lg leading-relaxed" set:html={h.bodyHtml} />
          ) : (
            <p class="text-lg leading-relaxed">{h.body}</p>
          )}
        </div>
      ))
    }
  </div>
</section>
