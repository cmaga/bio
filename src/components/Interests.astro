---
const interests = [
  {
    label: "01 — GAMING",
    body: "Competitive games, mostly. A way to stay sharp and stay connected.",
  },
  {
    label: "02 — RACING",
    body: "Cars in general. Go-karting, F1 weekends, sim rig at home. Gran Turismo is the forever favorite.",
  },
  {
    label: "03 — INVESTING",
    body: "Markets and capital allocation. Not Warren Buffett yet. Reading constantly.",
  },
];
---

<section id="interests" class="py-24">
  <div class="eyebrow mb-4"><span class="mark">◈</span> 03 / INTERESTS</div>
  <h2
    class="text-4xl md:text-6xl text-[var(--white)] font-light tracking-tight mb-12"
  >
    Beyond the keyboard.
  </h2>
  <div class="grid md:grid-cols-3 gap-5">
    {
      interests.map((i) => (
        <div class="card">
          <div class="card-num mb-4">{i.label}</div>
          <p class="text-base leading-relaxed font-light">{i.body}</p>
        </div>
      ))
    }
  </div>
</section>
