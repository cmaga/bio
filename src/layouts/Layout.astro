---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Christopher Magana — Software Engineer",
  description = "Software engineer building resilient systems — from embedded robotics to production-scale infrastructure.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="Software Engineer, Python, C++, Machine Learning, Deep Learning, Startups, Agile, Embedded Systems, Robotics"
    />
    <meta name="author" content="Christopher Magana" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <link rel="icon" type="image/png" href="/img/icon.png" />
    <link rel="canonical" href={Astro.url.href} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen">
    <div class="intro" aria-hidden="true">
      <svg class="intro-rocket" viewBox="0 0 24 40" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 2 C 16 9, 16 20, 16 26 L 8 26 C 8 20, 8 9, 12 2 Z" stroke="#f8fafc" stroke-width="1.1" fill="rgba(96,165,250,0.08)"/>
        <circle cx="12" cy="13" r="1.8" stroke="#60a5fa" stroke-width="1"/>
        <path d="M8 22 L 4 28 L 8 26" stroke="#f59e0b" stroke-width="1"/>
        <path d="M16 22 L 20 28 L 16 26" stroke="#f59e0b" stroke-width="1"/>
        <path d="M10 27 Q 12 32 14 27" stroke="#f59e0b" stroke-width="1" opacity="0.9"/>
      </svg>
    </div>
    <slot />
  </body>
</html>
