---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Resume — Christopher Magana"
  description="Resume of Christopher Magana, Software Engineer."
>
  <Nav variant="page" />
  <main class="mx-auto max-w-6xl px-6 pb-24">
    <section class="py-12 md:py-16">
      <div class="eyebrow mb-4"><span class="mark">◈</span> 00 / RESUME</div>
      <div
        class="flex flex-wrap items-end justify-between gap-6 mb-10 border-b border-[var(--border)] pb-8"
      >
        <h1
          class="text-4xl md:text-6xl text-[var(--white)] font-light tracking-tight"
        >
          Resume <span class="text-[var(--amber)]">/</span> Dossier
        </h1>
        <div class="flex gap-3">
          <a class="btn" href="/resume.pdf" download>Download PDF</a>
          <a class="btn btn-ghost" href="/">← Back</a>
        </div>
      </div>

      <div
        class="card p-0 overflow-hidden"
        style="min-height: 80vh; padding: 0;"
      >
        <object
          data="/resume.pdf"
          type="application/pdf"
          width="100%"
          height="100%"
          style="min-height: 80vh; display: block; background: #0f172a;"
        >
          <div class="p-12 text-center">
            <div class="eyebrow mb-4">
              <span class="mark">◈</span> PDF VIEWER UNAVAILABLE
            </div>
            <h2
              class="text-2xl text-[var(--white)] font-light mb-4"
            >
              Your browser can't display the PDF inline.
            </h2>
            <a class="btn" href="/resume.pdf" download>Download resume.pdf</a>
          </div>
        </object>
      </div>

      <div class="coord mt-6 text-right">
        ◈ resume.pdf · last updated on request
      </div>
    </section>
    <Footer />
  </main>
</Layout>
